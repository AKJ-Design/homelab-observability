# Copy to ".env" and fill in.  docker compose substitutes these into
# docker-compose.yml automatically.  (NOTE: Prometheus itself does NOT
# read .env — the Uptime Kuma key goes directly in prometheus.yml.)

# --- Bitcoin (from Umbrel Bitcoin app -> settings -> "RPC" / connection info) ---
# Host is usually your mini PC's LAN IP if 8332 is published on the host,
# e.g. 192.168.1.50.  See README "Wiring up the Bitcoin exporter".
BITCOIN_RPC_HOST=192.168.1.50
BITCOIN_RPC_PORT=8332
BITCOIN_RPC_USER=umbrel
BITCOIN_RPC_PASSWORD=replace-with-umbrel-rpc-password
